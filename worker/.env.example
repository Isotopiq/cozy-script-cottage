# Required ─ Supabase
SUPABASE_URL=https://your-supabase.example.com
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# Required ─ Worker identity (UUID shown in Admin → Workers after registering)
WORKER_ID=00000000-0000-0000-0000-000000000000

# Optional
POLL_INTERVAL_MS=3000
HEARTBEAT_INTERVAL_MS=15000
METRICS_INTERVAL_MS=5000

# Optional ─ comma-separated env var names to forward into spawned scripts.
# By default scripts only receive PATH/HOME/TMPDIR/LANG/LC_ALL plus
# RUN_ID/RUN_PARAMS. Add names here (e.g. HTTP_PROXY,PYTHONPATH) only if a
# script truly needs them. SUPABASE_*, WORKER_ID and other secrets are
# permanently blocked even if listed here.
EXTRA_ENV_ALLOWLIST=
